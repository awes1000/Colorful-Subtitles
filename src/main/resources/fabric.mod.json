{
	"schemaVersion": 1,
	"id": "colorfulsubtitles",
	"version": "${version}",
	"name": "Colorful Subtitles",
	"description": "Changes the color of subtitles based on their sound category.",
	"authors": [
		"haykam821"
	],
	"contact": {
		"homepage": "https://github.com/haykam821/Colorful-Subtitles#readme",
		"issues": "https://github.com/haykam821/Colorful-Subtitles/issues",
		"sources": "https://github.com/haykam821/Colorful-Subtitles"
	},
	"environment": "client",
	"entrypoints": {
		"modmenu": [
			"io.github.haykam821.colorfulsubtitles.modmenu.ColorfulSubtitlesModMenu"
		]
	},
	"mixins": [
		"colorfulsubtitles.mixin.json"
	],
